<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{fullName}} - Resume</title>
  {{> baseStyles}}
  <style>
    body { background: #faf7ff; color: #1f1330; }
    .sheet { background: #fff; padding: 30px; }
    .rr-name {
      font-family: "Palatino Linotype", Georgia, serif;
      color: #1f1330;
    }
    .headline { color: #7c3aed; font-weight: 700; margin-top: 6px; }
    .rr-section-title {
      color: #7c3aed;
      border-bottom: 1px solid #e9ddff;
    }
    .split {
      display: grid;
      grid-template-columns: 1.3fr 0.8fr;
      gap: 24px;
    }
    .aside {
      background: #faf5ff;
      border-radius: 18px;
      padding: 16px;
      align-self: start;
    }
  </style>
</head>
<body>
  <div class="sheet">
    <header class="rr-header">
      <h1 class="rr-name">{{fullName}}</h1>
      {{#if profile.headline}}<div class="headline">{{profile.headline}}</div>{{/if}}
      <div class="rr-contact">{{contactLine}}</div>
      {{#if links.length}}<div class="rr-contact">{{#each links}}{{this}}{{#unless @last}} | {{/unless}}{{/each}}</div>{{/if}}
    </header>

    <div class="split">
      <main>
        {{#if profile.summary}}
          <section class="rr-section">
            <h2 class="rr-section-title">Summary</h2>
            <p>{{profile.summary}}</p>
          </section>
        {{/if}}

        {{#if experience.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Experience</h2>
            {{#each experience}}
              <article class="rr-item">
                <div class="rr-item-title">{{role}}</div>
                <div class="rr-item-sub">{{company}}{{#if location}} | {{location}}{{/if}} · {{dateRange}}</div>
                {{#if highlights.length}}<ul class="rr-bullets">{{#each highlights}}<li>{{this}}</li>{{/each}}</ul>{{/if}}
              </article>
            {{/each}}
          </section>
        {{/if}}

        {{#if projects.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Projects</h2>
            {{#each projects}}
              <article class="rr-item">
                <div class="rr-item-title">{{name}}</div>
                {{#if summary}}<div class="rr-item-sub">{{summary}}</div>{{/if}}
              </article>
            {{/each}}
          </section>
        {{/if}}
      </main>

      <aside class="aside">
        {{#if education.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Education</h2>
            {{#each education}}
              <article class="rr-item">
                <div class="rr-item-title">{{degree}}</div>
                <div class="rr-item-sub">{{institution}}</div>
                <div class="rr-muted">{{dateRange}}</div>
              </article>
            {{/each}}
          </section>
        {{/if}}

        {{#if skills.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Skills</h2>
            <div class="rr-tags">{{#each skills}}<span class="rr-tag">{{name}}</span>{{/each}}</div>
          </section>
        {{/if}}

        {{#if certifications.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Certifications</h2>
            {{#each certifications}}<div class="rr-item-sub"><strong>{{name}}</strong>{{#if year}} · {{year}}{{/if}}</div>{{/each}}
          </section>
        {{/if}}

        {{#if languages.length}}
          <section class="rr-section">
            <h2 class="rr-section-title">Languages</h2>
            {{#each languages}}<div class="rr-item-sub">{{name}}{{#if proficiency}} · {{proficiency}}{{/if}}</div>{{/each}}
          </section>
        {{/if}}
      </aside>
    </div>
  </div>
</body>
</html>
