<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{fullName}} - Curriculum Vitae</title>
  {{> baseStyles}}
  <style>
    body {
      background: #ffffff;
      color: #1a1a1a;
      font-family: "Cambria", "Georgia", serif;
      line-height: 1.5;
    }
    .sheet {
      background: #ffffff;
      padding: 40px;
      max-width: 900px;
    }
    .rr-header {
      margin-bottom: 16px;
      padding-bottom: 8px;
      text-align: center;
      border-bottom: 2px solid #2c3e50;
    }
    .rr-name {
      font-size: 22px;
      font-weight: 600;
      margin: 0;
      color: #2c3e50;
      letter-spacing: 0.5px;
    }
    .rr-title {
      font-size: 12px;
      margin: 6px 0 0 0;
      color: #2c3e50;
      font-style: italic;
      font-weight: normal;
    }
    .contact-row {
      font-size: 10px;
      margin-top: 6px;
      color: #404040;
    }
    .rr-contact {
      font-size: 10px;
      margin-top: 3px;
      color: #404040;
    }
    .rr-section {
      margin-bottom: 14px;
      page-break-inside: avoid;
    }
    .rr-section-title {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin: 0 0 8px 0;
      padding: 0 0 4px 0;
      border-bottom: 1px solid #2c3e50;
      color: #2c3e50;
    }
    .rr-item {
      margin-bottom: 10px;
      page-break-inside: avoid;
    }
    .rr-item-title {
      font-weight: 600;
      font-size: 11px;
      margin: 0;
      color: #1a1a1a;
    }
    .rr-item-sub {
      font-size: 10px;
      color: #404040;
      margin: 2px 0;
      font-style: italic;
    }
    .rr-muted {
      font-size: 10px;
      color: #404040;
    }
    .date-range {
      font-size: 10px;
      color: #404040;
    }
    .rr-bullets {
      margin: 4px 0 0 20px;
      padding: 0;
      font-size: 10px;
      list-style-type: disc;
    }
    .rr-bullets li {
      margin: 2px 0;
      color: #404040;
      line-height: 1.4;
    }
    .rr-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 10px;
    }
    .rr-tag {
      display: inline-block;
      background-color: transparent;
      color: #2c3e50;
      padding: 0;
      border: none;
      font-weight: 600;
      font-size: 10px;
      margin-right: 8px;
    }
  </style>
</head>
<body>
  <div class="sheet">
    <header class="rr-header">
      <h1 class="rr-name">{{fullName}}</h1>
      {{#if profile.headline}}<p class="rr-title">{{profile.headline}}</p>{{/if}}
      <div class="contact-row">{{contactLine}}</div>
    </header>

    {{#if profile.summary}}
      <section class="rr-section">
        <h2 class="rr-section-title">Research Interests & Summary</h2>
        <p style="font-size: 10px; margin: 0; color: #404040; line-height: 1.6;">{{profile.summary}}</p>
      </section>
    {{/if}}

    {{#if education.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Education</h2>
        {{#each education}}
          <article class="rr-item">
            <div class="rr-item-title">{{degree}}</div>
            <div class="rr-item-sub">{{institution}}{{#if location}}, {{location}}{{/if}}</div>
            {{#if startDate}}<div class="date-range">{{startDate}}{{#if endDate}} - {{endDate}}{{/if}}</div>{{/if}}
            {{#if details}}<div style="font-size: 10px; color: #404040; margin-top: 2px;">{{details}}</div>{{/if}}
          </article>
        {{/each}}
      </section>
    {{/if}}

    {{#if experience.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Professional Experience</h2>
        {{#each experience}}
          <article class="rr-item">
            <div class="rr-item-title">{{role}}</div>
            <div class="rr-item-sub">{{company}}{{#if location}}, {{location}}{{/if}}</div>
            <div class="date-range">{{dateRange}}</div>
            {{#if highlights.length}}
              <ul class="rr-bullets">
                {{#each highlights}}<li>{{this}}</li>{{/each}}
              </ul>
            {{/if}}
          </article>
        {{/each}}
      </section>
    {{/if}}

    {{#if projects.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Publications & Research</h2>
        {{#each projects}}
          <article class="rr-item">
            <div class="rr-item-title">{{name}}</div>
            {{#if role}}<div class="rr-item-sub">{{role}}</div>{{/if}}
            {{#if summary}}<div class="rr-item-sub">{{summary}}</div>{{/if}}
          </article>
        {{/each}}
      </section>
    {{/if}}

    {{#if certifications.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Certifications & Grants</h2>
        {{#each certifications}}
          <article class="rr-item">
            <div class="rr-item-sub"><strong>{{name}}</strong>{{#if issuer}} - {{issuer}}{{/if}}{{#if year}} ({{year}}){{/if}}</div>
          </article>
        {{/each}}
      </section>
    {{/if}}

    {{#if skills.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Technical Skills & Expertise</h2>
        <div class="rr-tags">
          {{#each skills}}{{#if @first}}<span class="rr-tag">{{name}}</span>{{else}}<span class="rr-tag">{{name}}</span>{{/if}}{{/each}}
        </div>
      </section>
    {{/if}}

    {{#if languages.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Languages</h2>
        {{#each languages}}
          <div class="rr-item-sub"><strong>{{name}}</strong>{{#if proficiency}} - {{proficiency}}{{/if}}</div>
        {{/each}}
      </section>
    {{/if}}
  </div>
</body>
</html>
