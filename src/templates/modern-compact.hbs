<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{fullName}} - Resume</title>
  {{> baseStyles}}
  <style>
    body {
      background: #ffffff;
      color: #1a1a1a;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }
    .sheet {
      background: #ffffff;
      padding: 32px;
    }
    .rr-header {
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 2px solid #3b82f6;
    }
    .rr-name {
      font-size: 24px;
      font-weight: 700;
      margin: 0;
      color: #1a1a1a;
      letter-spacing: -0.5px;
    }
    .rr-title {
      font-size: 12px;
      margin: 6px 0 0 0;
      color: #3b82f6;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .contact-row {
      font-size: 10px;
      margin-top: 8px;
      color: #666666;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }
    .rr-contact {
      font-size: 10px;
      margin-top: 4px;
      color: #666666;
    }
    .rr-section {
      margin-bottom: 16px;
      page-break-inside: avoid;
    }
    .rr-section-title {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin: 0 0 10px 0;
      padding: 0 0 6px 0;
      border-bottom: 1px solid #e5e7eb;
      color: #1a1a1a;
    }
    .rr-item {
      margin-bottom: 10px;
      page-break-inside: avoid;
    }
    .item-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 3px;
    }
    .rr-item-title {
      font-weight: 600;
      font-size: 11px;
      margin: 0;
      color: #1a1a1a;
    }
    .rr-item-sub {
      font-size: 10px;
      color: #666666;
      margin: 2px 0;
    }
    .rr-muted {
      font-size: 10px;
      color: #999999;
      font-weight: 600;
    }
    .date-range {
      font-size: 10px;
      color: #999999;
      font-weight: 500;
      flex-shrink: 0;
    }
    .rr-bullets {
      margin: 4px 0 0 16px;
      padding: 0;
      font-size: 10px;
      list-style-type: disc;
    }
    .rr-bullets li {
      margin: 2px 0;
      color: #666666;
      line-height: 1.4;
    }
    .rr-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      font-size: 10px;
    }
    .rr-tag {
      display: inline-block;
      background-color: #eff6ff;
      color: #3b82f6;
      padding: 4px 8px;
      border-radius: 4px;
      border: 1px solid #dbeafe;
      font-weight: 500;
      font-size: 9px;
    }
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }
  </style>
</head>
<body>
  <div class="sheet">
    <header class="rr-header">
      <h1 class="rr-name">{{fullName}}</h1>
      {{#if profile.headline}}<p class="rr-title">{{profile.headline}}</p>{{/if}}
      <div class="contact-row">{{contactLine}}</div>
    </header>

    {{#if profile.summary}}
      <section class="rr-section">
        <h2 class="rr-section-title">Summary</h2>
        <p style="font-size: 10px; margin: 0; color: #666666; line-height: 1.6;">{{profile.summary}}</p>
      </section>
    {{/if}}

    {{#if experience.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Experience</h2>
        {{#each experience}}
          <article class="rr-item">
            <div class="item-header">
              <div>
                <div class="rr-item-title">{{role}}</div>
                <div class="rr-item-sub"><strong>{{company}}</strong>{{#if location}} · {{location}}{{/if}}</div>
              </div>
              <div class="date-range">{{dateRange}}</div>
            </div>
            {{#if highlights.length}}
              <ul class="rr-bullets">
                {{#each highlights}}<li>{{this}}</li>{{/each}}
              </ul>
            {{/if}}
          </article>
        {{/each}}
      </section>
    {{/if}}

    <div class="two-col">
      {{#if skills.length}}
        <section class="rr-section">
          <h2 class="rr-section-title">Skills</h2>
          <div class="rr-tags">
            {{#each skills}}<span class="rr-tag">{{name}}</span>{{/each}}
          </div>
        </section>
      {{/if}}

      {{#if education.length}}
        <section class="rr-section">
          <h2 class="rr-section-title">Education</h2>
          {{#each education}}
            <article class="rr-item">
              <div class="rr-item-title">{{degree}}</div>
              <div class="rr-item-sub"><strong>{{institution}}</strong></div>
              {{#if startDate}}<div class="rr-item-sub">{{startDate}}{{#if endDate}} - {{endDate}}{{/if}}</div>{{/if}}
            </article>
          {{/each}}
        </section>
      {{/if}}
    </div>

    {{#if projects.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Projects</h2>
        {{#each projects}}
          <article class="rr-item">
            <div class="item-header">
              <div>
                <div class="rr-item-title">{{name}}</div>
                {{#if role}}<div class="rr-item-sub">{{role}}</div>{{/if}}
              </div>
            </div>
            {{#if summary}}<div class="rr-item-sub">{{summary}}</div>{{/if}}
          </article>
        {{/each}}
      </section>
    {{/if}}

    {{#if certifications.length}}
      <section class="rr-section">
        <h2 class="rr-section-title">Certifications</h2>
        {{#each certifications}}
          <div class="rr-item-sub"><strong>{{name}}</strong>{{#if issuer}} · {{issuer}}{{/if}}{{#if year}} · {{year}}{{/if}}</div>
        {{/each}}
      </section>
    {{/if}}
  </div>
</body>
</html>
